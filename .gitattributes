# Auto detect text files and normalize to LF
* text=auto eol=lf

# Explicitly declare text files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows scripts should use CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files — don't touch
*.png binary
*.jpg binary
*.ico binary
